rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function currentUserDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function currentRole() {
      return signedIn() ? currentUserDoc().data.role : null;
    }

    function isSuperAdmin() {
      return signedIn() &&
        request.auth.token.email != null &&
        request.auth.token.email == '12yemom@gmail.com' &&
        currentRole() == 'super_admin';
    }

    function isAdmin() {
      return signedIn() && (currentRole() == 'admin' || currentRole() == 'super_admin');
    }

    function isSelf(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read: if signedIn() && (isSelf(userId) || isAdmin());

      // Signup can create own default user profile only.
      allow create: if isSelf(userId) &&
        request.resource.data.id == request.auth.uid &&
        request.resource.data.email == request.auth.token.email &&
        (
          (request.resource.data.role == 'user' && request.resource.data.approved == false) ||
          (
            request.auth.token.email == '12yemom@gmail.com' &&
            request.resource.data.role == 'super_admin' &&
            request.resource.data.approved == true
          )
        );

      // User can update personal non-privileged fields.
      allow update: if isSelf(userId) &&
        request.resource.data.role == resource.data.role &&
        request.resource.data.approved == resource.data.approved;

      // Super admin can manage admin lifecycle and user roles.
      allow update, delete: if isSuperAdmin();
    }

    match /products/{productId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /orders/{orderId} {
      allow read: if signedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if signedIn() &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.orderId == orderId;
      allow update: if isAdmin() ||
        (signedIn() && resource.data.userId == request.auth.uid &&
          request.resource.data.userId == resource.data.userId &&
          request.resource.data.driverId == resource.data.driverId &&
          request.resource.data.storeLocation == resource.data.storeLocation &&
          request.resource.data.customerLocation == resource.data.customerLocation &&
          request.resource.data.driverLocation == resource.data.driverLocation);
      allow delete: if isSuperAdmin();
    }

    match /payment_options/{paymentId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    match /auth_verification_codes/{userId} {
      allow create, read, update, delete: if isSelf(userId);
    }

    match /mail/{mailId} {
      allow create: if signedIn();
      allow read, update, delete: if isAdmin();
    }

    match /branches/{branchId} {
      allow read: if signedIn();
      allow create, update, delete: if isSuperAdmin();
    }
  }
}
