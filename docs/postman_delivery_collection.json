        "url": { "raw": "http://localhost:8000/api/drivers/login", "protocol": "http", "host": ["localhost"], "port": "8000", "path": ["api","drivers","login"] }
      }
    },
    {
      "name": "Get All Users (admin)",
      "request": {
        "method": "GET",
        "header": [],
        "url": { "raw": "http://localhost:8000/api/auth/users", "protocol": "http", "host": ["localhost"], "port": "8000", "path": ["api","auth","users"] }
      }
    }
