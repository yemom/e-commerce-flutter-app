        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Bob\",\n  \"phone\": \"+251912345678\",\n  \"password\": \"secret\",\n  \"vehicleType\": \"bike\",\n  \"licenseNumber\": \"ABC123\"\n}"
        },
        "url": { "raw": "http://localhost:8000/api/drivers/register", "protocol": "http", "host": ["localhost"], "port": "8000", "path": ["api","drivers","register"] }
      }
    },
    {
